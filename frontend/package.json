{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "generate-client": "openapi-generator-cli generate -i http://localhost:8080/v3/api-docs -g typescript-angular -o src/typescript-client"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.1.0",
    "@angular/cdk": "^21.1.0",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/platform-browser-dynamic": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@apollo/client": "^4.1.7",
    "@primeng/themes": "^19.0.0",
    "@primeuix/themes": "^2.0.3",
    "apollo-angular": "^13.0.0",
    "chart.js": "^4.5.1",
    "graphql": "^16.13.2",
    "graphql-ws": "^6.0.8",
    "ngx-cookie-service": "^21.3.1",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.1",
    "rxjs": "~7.8.0",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.1.2",
    "@angular/build": "^21.1.2",
    "@angular/cli": "^21.1.2",
    "@angular/compiler-cli": "^21.1.0",
    "@angular/localize": "^21.1.2",
    "@openapitools/openapi-generator-cli": "^2.30.2",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/jasmine": "^6.0.0",
    "@types/node": "^25.5.0",
    "jasmine-core": "^6.1.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.9.2",
    "zone.js": "^0.16.1"
  },
  "test": {
    "builder": "@angular/build:karma",
    "options": {
      "polyfills": [
        "zone.js",
        "zone.js/testing"
      ],
      "tsConfig": "tsconfig.spec.json",
      "karmaConfig": "karma.conf.js",
      "inlineStyleLanguage": "css",
      "assets": [
        {
          "glob": "**/*",
          "input": "public"
        }
      ],
      "styles": [
        "src/styles.css"
      ],
      "scripts": []
    }
  }
}
